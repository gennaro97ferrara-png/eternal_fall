# ============================================================================
# Eternal Fall — configurazione del bridge YouTube (server.js)
# Copia questo file in ".env" e riempi i valori. Il file .env NON va committato.
# Avvio:  node --env-file=.env server.js     (Node 20+)
#   oppure: esporta le variabili e fai `node server.js`
# Senza nulla di tutto questo il server gira lo stesso (serve solo il sito).
# ============================================================================

# Porta del server locale (default 8099)
PORT=8099

# --- CHAT dal vivo → una stella per ogni persona che scrive ---
# Modo più semplice: incolla l'ID del video della tua live (la parte dopo watch?v=)
YT_VIDEO_ID=
# (in alternativa, se lo conosci, l'ID della chat — salta la risoluzione)
YT_LIVE_CHAT_ID=
# API key di Google Cloud (Console → API e servizi → Credenziali → API key,
# con "YouTube Data API v3" abilitata). Serve a risolvere la chat dal video.
YT_API_KEY=

# --- OAuth (necessario per leggere la chat in modo affidabile e per gli ISCRITTI recenti) ---
# Crea credenziali OAuth "Desktop" in Google Cloud e ottieni un refresh token
# con scope: https://www.googleapis.com/auth/youtube.readonly
# (procedura nel README). Se li lasci vuoti: niente iscritti, chat solo se pubblica.
YT_OAUTH_CLIENT_ID=
YT_OAUTH_CLIENT_SECRET=
YT_OAUTH_REFRESH_TOKEN=

# Interruttori (1=on default, 0=off)
YT_CHAT=1
YT_SUBS=1

# Un nome non riaccende una stella entro questo tempo (ms). Default 15 min.
STAR_DEDUP_MS=900000
