# ───────── Eternal Fall · streaming nel cloud ─────────
# Copia queste righe nel tuo .env (nella ROOT del progetto, accanto a server.js),
# insieme alle eventuali chiavi YouTube che già usi per le stelle del pubblico.

# ─── OBBLIGATORIA ───
# La stream key di YouTube: YouTube Studio → "Trasmetti dal vivo" → Chiave stream.
YT_STREAM_KEY=xxxx-xxxx-xxxx-xxxx-xxxx

# ─── Qualità (default = 1080p60, identico al tuo OBS attuale) ───
RENDER_W=1920
RENDER_H=1080
FPS=60
VBITRATE=9M
VMAXRATE=9M
VBUF=18M
ABITRATE=160k

# Per 1440p60 (la banda è inclusa su Hetzner → puoi permettertelo):
#   RENDER_W=2560
#   RENDER_H=1440
#   VBITRATE=16M
#   VMAXRATE=16M
#   VBUF=32M

# Supersampling stile "retina" (più nitido a parità di output, costa più GPU):
# rende a 1440 e scala a 1080 →
#   RENDER_W=2560
#   RENDER_H=1440
#   OUT_W=1920
#   OUT_H=1080

# ─── Encoder NVENC ───
NVENC_PRESET=p5          # p1(veloce) … p7(qualità migliore)
NVENC_TUNE=hq            # hq | ll | ull
# VIDEO_ENCODER=h264_nvenc   # default. hevc_nvenc su tutte le NVIDIA recenti.
#                            # av1_nvenc SOLO su GPU Ada (es. RTX 4000 Ada di Hetzner),
#                            # NON sulle Ampere di TensorDock (A4000/A5000). Verifica l'ingest YouTube.

# ─── Robustezza / WebGL ───
ANGLE_BACKEND=vulkan     # default vulkan (consigliato NVIDIA in container); gl-egl se vulkan non parte
DEVICE_SCALE_FACTOR=1    # 2 = densità "retina" (più nitido, più GPU)
BROWSER_RESTART_HOURS=8  # riavvio periodico del browser anti memory-leak (0 = mai)
RTMP_URL=rtmp://a.rtmp.youtube.com/live2   # di norma non si tocca

# ─── (opzionali) chiavi YouTube per le stelle col nome del pubblico ───
# YT_API_KEY=...
# YT_VIDEO_ID=...
# YT_OAUTH_CLIENT_ID=...
# YT_OAUTH_CLIENT_SECRET=...
# YT_OAUTH_REFRESH_TOKEN=...
# ADMIN_TOKEN=metti-un-token-forte-qui   # IMPORTANTE: cambialo, l'admin è raggiungibile via tunnel
